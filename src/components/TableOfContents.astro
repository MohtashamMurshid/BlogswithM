---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const filteredHeadings = headings.filter((heading) => heading.depth <= 2);
---

{filteredHeadings.length > 0 && (
  <details class="toc-wrapper" open>
    <summary class="toc-toggle">
      <span>Contents</span>
      <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9" />
      </svg>
    </summary>
    <nav class="toc-nav" aria-label="Table of contents">
      <ul class="toc-list">
        {filteredHeadings.map((heading) => (
          <li class={heading.depth === 2 ? 'toc-item toc-item--sub' : 'toc-item'}>
            <a href={`#${heading.slug}`} class="toc-link">
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </details>
)}

<style>
  .toc-wrapper {
    margin-bottom: 2rem;
  }

  .toc-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: hsl(var(--fg-muted));
    user-select: none;
    list-style: none;
    transition: color 0.2s ease;
    padding: 0;
  }

  .toc-toggle::-webkit-details-marker {
    display: none;
  }

  .toc-toggle:hover {
    color: hsl(var(--fg));
  }

  .toc-toggle .chevron {
    margin-left: auto;
    transition: transform 0.2s ease;
  }

  details[open] .toc-toggle .chevron {
    transform: rotate(180deg);
  }

  .toc-nav {
    padding-top: 0.5rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin: 0;
  }

  .toc-item--sub {
    padding-left: 1rem;
  }

  .toc-link {
    display: block;
    padding: 0.25rem 0;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: hsl(var(--fg-muted));
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc-link:hover {
    color: hsl(var(--fg));
  }
</style>
