---
import "../styles/global.css";
import { getImagePath } from "astro-opengraph-images";
export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  showHeader?: boolean;
}

const {
  title = "BlogsWithM",
  description = "Articles, notes, and thoughts.",
  lang = "en",
  showHeader = false,
} = Astro.props as Props;

const currentUrl = Astro.url;
const canonicalUrl = currentUrl.href;
const brandName = "Mohtasham Murshid Madani";
const websiteName = "BlogsWithM";
const pageTitle = title?.includes(brandName) ? title : `${title} | ${brandName}`;
const siteUrl = Astro.site?.href ?? "https://blog.mohtasham.dev/";
const absoluteImage = new URL(getImagePath({ url: Astro.url, site: Astro.site }), siteUrl).href;
const rssUrl = new URL("/rss.xml", siteUrl).href;
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={`${description} — ${brandName}`} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${websiteName} RSS Feed`} href={rssUrl} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={`${description} — ${brandName}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={websiteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@mohtashamdotdev" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={`${description} — ${brandName}`} />
    <meta name="twitter:image" content={absoluteImage} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: websiteName,
      url: siteUrl,
      description: `${description} — ${brandName}`,
      publisher: {
        '@type': 'Person',
        name: brandName,
      },
      inLanguage: lang,
    })} />

    <slot name="head" />

    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (!window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col antialiased">
    {showHeader && (
      <header class="fixed top-0 left-0 right-0 z-50" style="background: hsl(var(--bg));">
        <div class="max-w-2xl mx-auto px-5 h-12 flex items-center justify-between">
          <a
            href="/"
            class="text-xs font-medium tracking-wide uppercase no-underline transition-opacity hover:opacity-50"
            style="color: hsl(var(--fg)); letter-spacing: 0.1em;"
          >
            M.
          </a>
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="w-7 h-7 flex items-center justify-center rounded-full transition-opacity hover:opacity-50"
            style="background: none; border: none; color: hsl(var(--fg-muted)); padding: 0;"
          >
            <svg class="sun-icon hidden dark:block" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
            </svg>
            <svg class="moon-icon block dark:hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
        </div>
      </header>
    )}

    <main class="flex-1">
      <slot />
    </main>

    <footer>
      <div class="max-w-2xl mx-auto px-5 py-12 text-center text-xs" style="color: hsl(var(--fg-muted));">
        <p>&copy; {new Date().getFullYear()} Mohtasham Murshid Madani</p>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', function() {
        const html = document.documentElement;
        const isDark = html.classList.contains('dark');
        html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
      });
    </script>
  </body>
</html>
