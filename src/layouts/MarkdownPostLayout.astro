---
import "../styles/global.css";
import TableOfContents from "../components/TableOfContents.astro";
import type { MarkdownHeading } from "astro";

type Frontmatter = {
  title?: string;
  author?: string;
  department?: string;
  university?: string;
  email?: string;
  description?: string;
  pubDate?: string | Date;
  tags?: string[];
};

type Props = {
  frontmatter: Frontmatter;
  headings: MarkdownHeading[];
};

const { frontmatter, headings } = Astro.props as Props;
const pageUrl = Astro.url.href;
const siteUrl = Astro.site?.href ?? "https://blog.mohtasham.dev/";
const ogImage = new URL("/favicon.svg", Astro.site).href;
const brandName = "Mohtasham Murshid Madani";
const pageTitle = frontmatter.title
  ? `${frontmatter.title} | ${brandName}`
  : brandName;

const formattedDate = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

let readingTime = 5;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {frontmatter.description && (
      <meta name="description" content={`${frontmatter.description} — ${brandName}`} />
    )}
    <link rel="canonical" href={pageUrl} />

    <meta property="og:title" content={pageTitle} />
    {frontmatter.description && (
      <meta property="og:description" content={`${frontmatter.description} — ${brandName}`} />
    )}
    <meta property="og:type" content="article" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    {frontmatter.description && (
      <meta name="twitter:description" content={`${frontmatter.description} — ${brandName}`} />
    )}
    <meta name="twitter:image" content={ogImage} />
    {frontmatter.pubDate && (
      <meta property="article:published_time" content={new Date(frontmatter.pubDate).toISOString()} />
    )}

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: frontmatter.title,
      description: frontmatter.description ?? undefined,
      datePublished: frontmatter.pubDate
        ? new Date(frontmatter.pubDate).toISOString()
        : undefined,
      author: frontmatter.author
        ? { '@type': 'Person', name: frontmatter.author }
        : { '@type': 'Person', name: brandName },
      mainEntityOfPage: pageUrl,
      image: ogImage,
      url: pageUrl,
    })} />

    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (!window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="antialiased" style="background-color: hsl(var(--bg)); color: hsl(var(--fg));">
    <!-- Navigation -->
    <header class="sticky top-0 z-50 backdrop-blur-lg border-b" style="background: hsl(var(--bg) / 0.85); border-color: hsl(var(--border));">
      <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="inline-flex items-center gap-2 text-sm no-underline transition-opacity hover:opacity-70" style="color: hsl(var(--fg-muted));">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back
        </a>
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="w-8 h-8 flex items-center justify-center rounded-full transition-colors"
          style="background: none; border: none; color: hsl(var(--fg-muted)); padding: 0;"
        >
          <svg class="sun-icon hidden dark:block" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg>
          <svg class="moon-icon block dark:hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-12 sm:py-16 animate-fade-up">
      <!-- Article Header -->
      <header class="mb-10">
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="flex items-center gap-2 mb-4 flex-wrap">
            {frontmatter.tags.slice(0, 4).map((tag: string) => (
              <span
                class="text-xs font-medium px-2.5 py-1 rounded-full"
                style="color: hsl(var(--accent)); background: hsl(var(--accent) / 0.1); border: 1px solid hsl(var(--accent) / 0.15);"
              >
                {tag}
              </span>
            ))}
          </div>
        )}

        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight" style="color: hsl(var(--fg)); font-family: Inter, system-ui, sans-serif; text-wrap: balance;">
          {frontmatter.title}
        </h1>

        <div class="mt-5 flex items-center gap-3 flex-wrap text-sm" style="color: hsl(var(--fg-muted));">
          {frontmatter.author && (
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold"
                style="background: linear-gradient(135deg, hsl(var(--accent)), hsl(var(--accent-muted))); color: white;">
                {frontmatter.author.charAt(0)}
              </div>
              <span class="font-medium" style="color: hsl(var(--fg));">{frontmatter.author}</span>
            </div>
          )}
          {frontmatter.author && formattedDate && (
            <span style="color: hsl(var(--border))">·</span>
          )}
          {formattedDate && (
            <time datetime={new Date(frontmatter.pubDate!).toISOString()}>
              {formattedDate}
            </time>
          )}
        </div>

        {frontmatter.description && (
          <p class="mt-5 text-lg leading-relaxed" style="color: hsl(var(--fg-muted)); font-family: 'Source Serif 4', Georgia, serif;">
            {frontmatter.description}
          </p>
        )}
      </header>

      <div class="w-full h-px mb-10" style="background: hsl(var(--border))"></div>

      {headings.length > 0 && <TableOfContents headings={headings} />}

      <!-- Article Content -->
      <article class="prose">
        <slot />
      </article>

      <!-- Article Footer -->
      <footer class="mt-16 pt-8 border-t" style="border-color: hsl(var(--border));">
        <div class="flex items-center justify-between">
          <a
            href="/"
            class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-lg transition-colors no-underline"
            style="color: hsl(var(--fg-muted)); background: hsl(var(--surface)); border: 1px solid hsl(var(--border));"
            onmouseenter="this.style.borderColor='hsl(var(--accent))'; this.style.color='hsl(var(--accent))'"
            onmouseleave="this.style.borderColor='hsl(var(--border))'; this.style.color='hsl(var(--fg-muted))'"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            All articles
          </a>
        </div>

        <div class="mt-10 py-6 text-center text-xs" style="color: hsl(var(--fg-muted))">
          <p>&copy; {new Date().getFullYear()} Mohtasham Murshid Madani</p>
        </div>
      </footer>
    </main>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', function() {
        const html = document.documentElement;
        const isDark = html.classList.contains('dark');
        html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
      });
    </script>

    <style>
      .animate-fade-up {
        animation: fadeUp 0.6s ease-out;
      }

      @keyframes fadeUp {
        0% { opacity: 0; transform: translateY(16px); }
        100% { opacity: 1; transform: translateY(0); }
      }
    </style>
  </body>
</html>
