---
import "../styles/global.css";
import TableOfContents from "../components/TableOfContents.astro";
import type { MarkdownHeading } from "astro";

type Frontmatter = {
  title?: string;
  author?: string;
  department?: string;
  university?: string;
  email?: string;
  description?: string;
  pubDate?: string | Date;
  tags?: string[];
};

type Props = {
  frontmatter: Frontmatter;
  headings: MarkdownHeading[];
};

const { frontmatter, headings } = Astro.props as Props;
const pageUrl = Astro.url.href;
const siteUrl = Astro.site?.href ?? "https://blog.mohtasham.dev/";
const ogImage = new URL("/favicon.svg", Astro.site).href;
const brandName = "Mohtasham Murshid Madani";
const pageTitle = frontmatter.title
  ? `${frontmatter.title} | ${brandName}`
  : brandName;

const formattedDate = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {frontmatter.description && (
      <meta name="description" content={`${frontmatter.description} — ${brandName}`} />
    )}
    <link rel="canonical" href={pageUrl} />

    <meta property="og:title" content={pageTitle} />
    {frontmatter.description && (
      <meta property="og:description" content={`${frontmatter.description} — ${brandName}`} />
    )}
    <meta property="og:type" content="article" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    {frontmatter.description && (
      <meta name="twitter:description" content={`${frontmatter.description} — ${brandName}`} />
    )}
    <meta name="twitter:image" content={ogImage} />
    {frontmatter.pubDate && (
      <meta property="article:published_time" content={new Date(frontmatter.pubDate).toISOString()} />
    )}

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: frontmatter.title,
      description: frontmatter.description ?? undefined,
      datePublished: frontmatter.pubDate
        ? new Date(frontmatter.pubDate).toISOString()
        : undefined,
      author: frontmatter.author
        ? { '@type': 'Person', name: frontmatter.author }
        : { '@type': 'Person', name: brandName },
      mainEntityOfPage: pageUrl,
      image: ogImage,
      url: pageUrl,
    })} />

    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (!window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="antialiased" style="background-color: hsl(var(--bg)); color: hsl(var(--fg));">
    <header class="fixed top-0 left-0 right-0 z-50" style="background: hsl(var(--bg));">
      <div class="max-w-2xl mx-auto px-5 h-12 flex items-center justify-between">
        <a
          href="/"
          class="text-xs no-underline transition-opacity hover:opacity-50 flex items-center gap-1.5"
          style="color: hsl(var(--fg-muted));"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back
        </a>
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="w-7 h-7 flex items-center justify-center rounded-full transition-opacity hover:opacity-50"
          style="background: none; border: none; color: hsl(var(--fg-muted)); padding: 0;"
        >
          <svg class="sun-icon hidden dark:block" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg>
          <svg class="moon-icon block dark:hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      </div>
    </header>

    <main class="max-w-2xl mx-auto px-5 pt-24 pb-16">
      <header class="mb-10">
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight leading-tight text-balance" style="color: hsl(var(--fg)); font-family: Inter, system-ui, sans-serif;">
          {frontmatter.title}
        </h1>

        <div class="mt-4 flex items-center gap-2 text-xs" style="color: hsl(var(--fg-muted));">
          {frontmatter.author && (
            <span>{frontmatter.author}</span>
          )}
          {frontmatter.author && formattedDate && (
            <span>&middot;</span>
          )}
          {formattedDate && (
            <time datetime={new Date(frontmatter.pubDate!).toISOString()}>
              {formattedDate}
            </time>
          )}
        </div>

        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="mt-4 flex items-center gap-2 flex-wrap">
            {frontmatter.tags.slice(0, 4).map((tag: string) => (
              <span
                class="text-xs px-2 py-0.5 rounded"
                style="color: hsl(var(--fg-muted)); background: hsl(var(--surface));"
              >
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="w-full h-px mb-8" style="background: hsl(var(--border));"></div>

      {headings.length > 0 && <TableOfContents headings={headings} />}

      <article class="prose">
        <slot />
      </article>

      <footer class="mt-16 pt-8" style="border-top: 1px solid hsl(var(--border));">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-xs no-underline transition-opacity hover:opacity-50"
          style="color: hsl(var(--fg-muted));"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          All articles
        </a>

        <div class="mt-10 text-center text-xs" style="color: hsl(var(--fg-muted));">
          <p>&copy; {new Date().getFullYear()} Mohtasham Murshid Madani</p>
        </div>
      </footer>
    </main>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', function() {
        const html = document.documentElement;
        const isDark = html.classList.contains('dark');
        html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
      });
    </script>
  </body>
</html>
