---
import Layout from "../layouts/Layout.astro";
const allPosts = Object.values(
  import.meta.glob("./posts/*.md", { eager: true })
);

const sortedPosts = allPosts.sort((a: any, b: any) => {
  const dateA = new Date(a.frontmatter.pubDate);
  const dateB = new Date(b.frontmatter.pubDate);
  return dateB.getTime() - dateA.getTime();
});
---

<Layout
  title="Articles"
  description="Writing on software, notes, and experiments."
  showHeader={true}
>
  <div class="max-w-3xl mx-auto px-6 pt-20 pb-16 animate-fade-up">
    <!-- Hero -->
    <header class="mb-16">
      <div class="flex items-start gap-5 mb-6">
        <div class="w-14 h-14 rounded-full flex items-center justify-center text-xl font-bold shrink-0"
          style="background: linear-gradient(135deg, hsl(var(--accent)), hsl(var(--accent-muted))); color: white;">
          M
        </div>
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold tracking-tight" style="color: hsl(var(--fg)); line-height: 1.2;">
            Mohtasham Murshid Madani
          </h1>
          <p class="mt-1 text-sm" style="color: hsl(var(--fg-muted))">
            Software engineer & writer
          </p>
        </div>
      </div>

      <p class="text-base leading-relaxed max-w-xl" style="color: hsl(var(--fg-muted))">
        Minimal notes on the web. Writing about software engineering,
        machine learning, and ideas worth exploring.
      </p>

      <nav class="mt-5 flex items-center gap-3 text-sm flex-wrap">
        <a
          href="https://github.com/MohtashamMurshid"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full transition-colors"
          style="color: hsl(var(--fg-muted)); background: hsl(var(--surface)); border: 1px solid hsl(var(--border));"
          onmouseenter="this.style.borderColor='hsl(var(--accent))'; this.style.color='hsl(var(--accent))'"
          onmouseleave="this.style.borderColor='hsl(var(--border))'; this.style.color='hsl(var(--fg-muted))'"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="https://x.com/mohtashamdotdev"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full transition-colors"
          style="color: hsl(var(--fg-muted)); background: hsl(var(--surface)); border: 1px solid hsl(var(--border));"
          onmouseenter="this.style.borderColor='hsl(var(--accent))'; this.style.color='hsl(var(--accent))'"
          onmouseleave="this.style.borderColor='hsl(var(--border))'; this.style.color='hsl(var(--fg-muted))'"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          Twitter
        </a>
        <a
          href="https://www.linkedin.com/in/mohtashammurshid"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full transition-colors"
          style="color: hsl(var(--fg-muted)); background: hsl(var(--surface)); border: 1px solid hsl(var(--border));"
          onmouseenter="this.style.borderColor='hsl(var(--accent))'; this.style.color='hsl(var(--accent))'"
          onmouseleave="this.style.borderColor='hsl(var(--border))'; this.style.color='hsl(var(--fg-muted))'"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a
          href="mailto:contact@mohtasham.dev"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full transition-colors"
          style="color: hsl(var(--fg-muted)); background: hsl(var(--surface)); border: 1px solid hsl(var(--border));"
          onmouseenter="this.style.borderColor='hsl(var(--accent))'; this.style.color='hsl(var(--accent))'"
          onmouseleave="this.style.borderColor='hsl(var(--border))'; this.style.color='hsl(var(--fg-muted))'"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Email
        </a>
      </nav>
    </header>

    <!-- Posts -->
    <section aria-label="Articles">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--fg-muted))">
          Articles
        </h2>
        <div class="h-px flex-1 ml-4" style="background: hsl(var(--border))"></div>
      </div>

      <div class="space-y-2">
        {
          sortedPosts.map((post: any, i: number) => (
            <article
              class="group relative"
              style={`animation-delay: ${i * 60}ms`}
            >
              <a
                href={post.url}
                class="block rounded-xl px-4 py-4 -mx-4 transition-all duration-200 no-underline"
                style="color: inherit;"
                onmouseenter="this.style.background='hsl(var(--surface))'"
                onmouseleave="this.style.background='transparent'"
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <h3 class="text-base font-medium leading-snug group-hover:translate-x-0.5 transition-transform duration-200" style="color: hsl(var(--fg))">
                      {post.frontmatter.title}
                    </h3>
                    {post.frontmatter.description && (
                      <p class="mt-1 text-sm line-clamp-2 leading-relaxed" style="color: hsl(var(--fg-muted))">
                        {post.frontmatter.description.length > 120
                          ? post.frontmatter.description.slice(0, 120) + '...'
                          : post.frontmatter.description}
                      </p>
                    )}
                    {post.frontmatter.tags && (
                      <div class="mt-2 flex items-center gap-2 flex-wrap">
                        {post.frontmatter.tags.slice(0, 3).map((tag: string) => (
                          <span
                            class="text-xs px-2 py-0.5 rounded-full"
                            style="color: hsl(var(--accent)); background: hsl(var(--accent) / 0.1); border: 1px solid hsl(var(--accent) / 0.15);"
                          >
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                  <time
                    class="text-xs font-mono shrink-0 pt-1"
                    style="color: hsl(var(--fg-muted))"
                    datetime={new Date(post.frontmatter.pubDate).toISOString()}
                  >
                    {new Date(post.frontmatter.pubDate).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                    })}
                  </time>
                </div>
                <div
                  class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                  style="color: hsl(var(--fg-muted))"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
