---
import Layout from "../layouts/Layout.astro";
const allPosts = Object.values(
  import.meta.glob("./posts/*.md", { eager: true })
);

const sortedPosts = allPosts.sort((a: any, b: any) => {
  const dateA = new Date(a.frontmatter.pubDate);
  const dateB = new Date(b.frontmatter.pubDate);
  return dateB.getTime() - dateA.getTime();
});
---

<Layout
  title="Articles"
  description="Writing on software, notes, and experiments."
  showHeader={true}
>
  <div class="max-w-2xl mx-auto px-5 pt-24 pb-20">
    <header class="mb-20">
      <h1 class="text-lg font-medium tracking-tight" style="color: hsl(var(--fg));">
        Mohtasham Murshid Madani
      </h1>
      <p class="mt-3 text-sm leading-relaxed max-w-md" style="color: hsl(var(--fg-muted));">
        Software engineer. Writing about code, machine learning,
        and things I find interesting.
      </p>

      <nav class="mt-5 flex items-center gap-4 text-sm">
        <a
          href="https://github.com/MohtashamMurshid"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors"
          style="color: hsl(var(--fg-muted));"
          onmouseenter="this.style.color='hsl(var(--fg))'"
          onmouseleave="this.style.color='hsl(var(--fg-muted))'"
        >GitHub</a>
        <a
          href="https://x.com/mohtashamdotdev"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors"
          style="color: hsl(var(--fg-muted));"
          onmouseenter="this.style.color='hsl(var(--fg))'"
          onmouseleave="this.style.color='hsl(var(--fg-muted))'"
        >Twitter</a>
        <a
          href="https://www.linkedin.com/in/mohtashammurshid"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors"
          style="color: hsl(var(--fg-muted));"
          onmouseenter="this.style.color='hsl(var(--fg))'"
          onmouseleave="this.style.color='hsl(var(--fg-muted))'"
        >LinkedIn</a>
        <a
          href="mailto:contact@mohtasham.dev"
          class="transition-colors"
          style="color: hsl(var(--fg-muted));"
          onmouseenter="this.style.color='hsl(var(--fg))'"
          onmouseleave="this.style.color='hsl(var(--fg-muted))'"
        >Email</a>
      </nav>
    </header>

    <section aria-label="Articles">
      <h2 class="text-xs uppercase tracking-widest mb-8" style="color: hsl(var(--fg-muted)); letter-spacing: 0.12em;">
        Writing
      </h2>

      <div class="space-y-0">
        {
          sortedPosts.map((post: any) => (
            <a
              href={post.url}
              class="group flex items-baseline justify-between gap-4 py-3 no-underline border-b transition-colors"
              style="color: inherit; border-color: hsl(var(--border));"
            >
              <span class="text-sm font-normal group-hover:opacity-60 transition-opacity" style="color: hsl(var(--fg));">
                {post.frontmatter.title}
              </span>
              <time
                class="text-xs font-mono shrink-0"
                style="color: hsl(var(--fg-muted));"
                datetime={new Date(post.frontmatter.pubDate).toISOString()}
              >
                {new Date(post.frontmatter.pubDate).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                })}
              </time>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
